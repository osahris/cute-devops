# reference-transaction fires on every ref update — local commits, pushes,
# rebases, fetches. We hook into two phases:
#   prepared  -> reject non-fast-forward updates and deletions of main
#   committed -> sync tests/* from main's new tree into the shared hooks
#                directory, so every worktree picks up hook changes

set -euo pipefail

# Remotes that should mirror main automatically. Edit this list to add or
# remove targets; missing remotes are skipped silently.
PUSH_TARGETS=(github gitlab codeberg)

state=$1
zero="0000000000000000000000000000000000000000"

case "$state" in
prepared)
    while read -r oldrev newrev ref; do
        [ "$ref" = "refs/heads/main" ] || continue
        [ "$oldrev" = "$zero" ] && continue

        if [ "$newrev" = "$zero" ]; then
            echo "reference-transaction: refusing to delete main" >&2
            exit 1
        fi

        if ! git merge-base --is-ancestor "$oldrev" "$newrev"; then
            echo "reference-transaction: refusing non-fast-forward update to main" >&2
            echo "  $oldrev is not an ancestor of $newrev" >&2
            exit 1
        fi

        # main's tip must be a merge commit, so changes always land via an
        # explicit merge from a side branch rather than as direct commits.
        parent_count=$(git rev-list --parents -n 1 "$newrev" | awk '{print NF - 1}')
        if [ "$parent_count" -lt 2 ]; then
            echo "reference-transaction: refusing update to main: tip is not a merge commit" >&2
            echo "  $newrev has $parent_count parent(s); main only accepts merge commits as the new tip" >&2
            exit 1
        fi
    done
    ;;
committed)
    hooksdir=$(git rev-parse --git-common-dir)/hooks
    while read -r _oldrev newrev ref; do
        [ "$ref" = "refs/heads/main" ] || continue
        [ "$newrev" = "$zero" ] && continue

        tmp=$(mktemp -d)
        if git archive "$newrev" tests 2>/dev/null | tar -x -C "$tmp"; then
            shopt -s nullglob
            for src in "$tmp"/tests/*; do
                [ -f "$src" ] || continue
                install -m 755 "$src" "$hooksdir/$(basename "$src")"
            done
            echo "reference-transaction: synced tests/* from $newrev -> $hooksdir/" >&2
        fi
        rm -rf "$tmp"

        # Auto-push main to every configured mirror so the public copies
        # track the bare repo without manual intervention. Failures (no
        # network, auth, non-FF on the remote) warn but don't block the
        # local update, and a failure on one remote doesn't skip the rest.
        for remote in "${PUSH_TARGETS[@]}"; do
            git remote get-url "$remote" >/dev/null 2>&1 || continue
            if push_output=$(git push "$remote" main 2>&1); then
                echo "reference-transaction: pushed main to $remote" >&2
            else
                echo "reference-transaction: WARNING — auto-push to $remote failed:" >&2
                printf '  %s\n' "$push_output" >&2
            fi
        done
    done
    ;;
esac

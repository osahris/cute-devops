# Lint a copy of the staged tree, so the linters see exactly what would be
# committed regardless of unstaged changes in the working tree.

set -euo pipefail

for cmd in ansible-lint reuse; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "pre-commit: '$cmd' not found in PATH" >&2
        echo "  install with: apt-get install ansible-lint reuse" >&2
        exit 1
    fi
done

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

git checkout-index --all --prefix="$tmpdir/"

failed=0

# reuse lint runs first because it inspects every file on disk and does not
# honour .gitignore; ansible-lint generates .ansible/collections/... during
# its run, which would then trip reuse with missing-license noise.
echo "pre-commit: reuse lint"
if ! (cd "$tmpdir" && reuse lint); then
    failed=1
fi

echo "pre-commit: ansible-lint"
if ! (cd "$tmpdir" && ansible-lint); then
    failed=1
fi

if [ "$failed" -ne 0 ]; then
    echo >&2
    echo "pre-commit: checks failed against the staged tree; fix and re-stage." >&2
    exit 1
fi

# Central Caddyfile for *Cute Devops!*.
#
# Today this serves the documentation website. Additional services
# (e.g. an MCP server) will be mounted as further handle blocks below.
#
# URL contract:
#   /foo            HTML render        (browser, Accept: text/html)
#   /foo            302 → /foo.md      (curl & friends, no text/html)
#   /foo.md         raw markdown
#
{
	auto_https off
	admin off
	log default {
		level INFO
		format console
	}
}

# Snippet: render a page through the layout template. Callers must set
# the `page_file` and `page_edit` vars first.
(render_page) {
	rewrite * /templates/layout.html
	templates {
		mime text/html
		# Use non-Mustache delimiters so role READMEs containing
		# Ansible Jinja syntax ({{ inventory_hostname }} & friends)
		# are inert when included for front-matter / markdown rendering.
		between "[[" "]]"
	}
	header Content-Type "text/html; charset=utf-8"
	file_server
}

:8080 {
	root * /srv
	encode gzip zstd

	# --- Future services go here ---------------------------------
	# Example, once an MCP backend exists:
	#
	#   handle_path /mcp/* {
	#       reverse_proxy 127.0.0.1:9000
	#   }
	# -------------------------------------------------------------

	# Static assets, served verbatim from /srv/static/.
	handle /static/* {
		file_server
	}
	handle /favicon.ico {
		rewrite * /static/unicorn.svg
		file_server
	}

	# Liveness probe.
	handle /healthz {
		respond "ok" 200
	}

	# Dynamic sitemap — no content file; the template enumerates
	# /content/ at request time.
	handle /sitemap {
		rewrite * /templates/sitemap.html
		templates {
			mime text/html
			between "[[" "]]"
		}
		header Content-Type "text/html; charset=utf-8"
		file_server
	}

	# Root: browser → render the README; non-html clients → /README.md.
	@root_no_html {
		path /
		not header Accept *text/html*
	}
	handle @root_no_html {
		redir * /README.md 302
	}
	handle / {
		vars page_file "/content/README.md"
		vars page_edit "/README.md"
		import render_page
	}

	# `.md` URLs: serve the original markdown verbatim.
	@md_raw {
		path *.md
		file /content{path}
	}
	handle @md_raw {
		rewrite * /content{path}
		header Content-Type "text/markdown; charset=utf-8"
		file_server
	}

	# Clean URLs without a text/html Accept header → redirect to the
	# matching `.md` source. Two flavours: direct file, and the
	# Ansible-role-style folder where the README lives one level down.
	@clean_no_html_direct {
		not header Accept *text/html*
		file {
			try_files /content{path}.md
		}
	}
	handle @clean_no_html_direct {
		redir * {path}.md 302
	}
	@clean_no_html_readme {
		not header Accept *text/html*
		file {
			try_files /content{path}/README.md
		}
	}
	handle @clean_no_html_readme {
		redir * {path}/README.md 302
	}

	# Clean URLs with a text/html Accept header → render the page.
	@pattern_direct file {
		try_files /content{path}.md
	}
	handle @pattern_direct {
		vars page_file {http.matchers.file.relative}
		vars page_edit "{path}.md"
		import render_page
	}

	# Folder fallback: render <path>/README.md (used by Ansible roles
	# under /roles/<name>, where the README lives inside the role dir).
	@pattern_readme file {
		try_files /content{path}/README.md
	}
	handle @pattern_readme {
		vars page_file {http.matchers.file.relative}
		vars page_edit "{path}/README.md"
		import render_page
	}

	# Anything else: fall through to the error template.
	handle {
		error 404
	}

	handle_errors {
		rewrite * /templates/error.html
		templates {
			mime text/html
			between "[[" "]]"
		}
		header Content-Type "text/html; charset=utf-8"
		file_server
	}
}

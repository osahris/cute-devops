# This file is managed by the mkbrechtel.devops.webhook_server Ansible role!
# MANUAL CHANGES WILL BE OVERWRITTEN WITHOUT WARNING!

[Unit]
Description=Webhook server
After=network.target

[Service]
Type=simple
User={{ webhook_server_user }}
Group={{ webhook_server_group }}
ExecStart=/usr/bin/webhook -hooks {{ webhook_server_config_file }} -ip {{ webhook_server_listen_address }} -port {{ webhook_server_port }} -verbose -hotreload -logfile {{ webhook_server_log_file }}
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening - adjusted to allow sudo
NoNewPrivileges=false
PrivateTmp=false
ProtectSystem=false
ProtectHome=false
ReadWritePaths={{ webhook_server_log_dir }} {{ webhook_server_config_dir }}
ProtectKernelTunables=true
ProtectControlGroups=true
RestrictSUIDSGID=false
RestrictRealtime=true

[Install]
WantedBy=multi-user.target
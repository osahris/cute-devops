$ORIGIN test.example.
$TTL 3600

@  IN  SOA  ns1.test.example.  admin.test.example. (
              2026032601  ; serial
              3600        ; refresh
              900         ; retry
              604800      ; expire
              86400       ; minimum TTL
          )

   IN  NS   ns1.test.example.

ns1  IN  A  127.0.0.1

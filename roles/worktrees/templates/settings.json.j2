{
  "worktree": {
    "bgIsolation": "worktree"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ _wt_workdir }}/.claude/hooks/worktree-create"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ _wt_workdir }}/.claude/hooks/worktree-remove"
          }
        ]
      }
    ]
  }
}

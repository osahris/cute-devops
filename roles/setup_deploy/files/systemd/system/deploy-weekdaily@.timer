[Unit]
Description=Deploy %i weekdaily at 10am (from Monday to Thursday; no deploys on Fridays!!)!

[Timer]
OnCalendar=Mon..Thu *-*-* 10:00:00
RandomizedDelaySec=1800
Unit=deploy@%i.service

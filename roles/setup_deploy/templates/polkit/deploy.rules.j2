// This file is managed by the mkbrechtel.devops.setup_deploy Ansible role!
// MANUAL CHANGES WILL BE OVERWRITTEN WITHOUT WARNING!
//
// Push-to-deploy: members of the {{ setup_deploy_polkit_group }} group may
// start any deploy@<id>.service instance without authentication. This is
// `start` only -- stop/restart/enable still fall through to admin auth.
polkit.addRule(function (action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        action.lookup("verb") == "start" &&
        /^deploy@.+\.service$/.test(action.lookup("unit")) &&
        subject.isInGroup("{{ setup_deploy_polkit_group }}")) {
        return polkit.Result.YES;
    }
});

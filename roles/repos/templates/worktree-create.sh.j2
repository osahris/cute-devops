#!/usr/bin/env bash
# This file is managed by the osahris.cute_devops.repos Ansible role (initial scaffold)!
# Once `main` has the canonical copy, the bare repo's reference-transaction hook
# syncs it from main on each merge and this file is no longer Ansible-managed.
set -euo pipefail

payload="$(cat || true)"

# Pull a name out of the JSON payload (try a few key variants).
extract() {
  printf '%s' "$payload" \
    | sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" \
    | head -n1
}
name="$(extract name)"
[ -z "$name" ] && name="$(extract worktree_name)"
[ -z "$name" ] && name="wt-$(date +%s)-$$"

# Reject `..` outright, then sanitise to [A-Za-z0-9._/-].
case "$name" in
  *..*) echo "worktree-create: refusing unsafe name '$name'" >&2; exit 1 ;;
esac
name="$(printf '%s' "$name" | tr -c 'A-Za-z0-9._/-' '-')"

# Resolve the project root: works from a bare repo, a treehouse, a normal
# clone, or a worktree of a clone.
common="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
if [ "$(git -C "$common" config --bool core.bare 2>/dev/null || echo false)" = "true" ]; then
  project_root="$common"
else
  project_root="$(dirname "$common")"
fi

target="$project_root/treehouses/$name"

if [ -e "$target/.git" ]; then
  printf '%s\n' "$target"
  exit 0
fi

mkdir -p "$(dirname "$target")"

if git -C "$common" show-ref --verify --quiet "refs/heads/$name"; then
  git -C "$common" worktree add "$target" "$name" >&2
else
  base="$(git -C "$common" symbolic-ref --short HEAD 2>/dev/null || echo main)"
  git -C "$common" worktree add -b "$name" "$target" "$base" >&2
fi

printf '%s\n' "$target"

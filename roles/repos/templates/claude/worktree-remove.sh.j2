#!/usr/bin/env bash
# This file is managed by the mkbrechtel.devops.repos Ansible role (initial scaffold)!
# Once `main` has the canonical copy, the bare repo's reference-transaction hook
# syncs it from main on each merge and this file is no longer Ansible-managed.
set -euo pipefail

payload="$(cat || true)"

extract() {
  printf '%s' "$payload" \
    | sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" \
    | head -n1
}
path="$(extract worktree_path)"
[ -z "$path" ] && path="$(extract path)"

if [ -z "$path" ]; then
  echo "worktree-remove: no path in payload" >&2
  exit 0
fi

# Resolve the project root the same way as worktree-create.
common="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
if [ "$(git -C "$common" config --bool core.bare 2>/dev/null || echo false)" = "true" ]; then
  project_root="$common"
else
  project_root="$(dirname "$common")"
fi

# Geofence: only act on paths inside <project-root>/treehouses/.
case "$path" in
  "$project_root"/treehouses/*) ;;
  *)
    echo "worktree-remove: refusing to remove $path (outside treehouses/)" >&2
    exit 1
    ;;
esac

git -C "$common" worktree remove "$path" 2>/dev/null \
  || git -C "$common" worktree remove --force "$path" 2>/dev/null \
  || rm -rf "$path"

git -C "$common" worktree prune >/dev/null 2>&1 || true

// This file is managed by the mkbrechtel.devops.vhosts Ansible role!
// MANUAL CHANGES WILL BE OVERWRITTEN WITHOUT WARNING!
//
// Push-to-deploy bridge for vhosts: members of the {{ vhosts_polkit_group }}
// group may start any deploy-vhost@<name>.service instance without
// authentication. `start` only -- stop/restart/enable fall through to
// admin auth.
polkit.addRule(function (action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        action.lookup("verb") == "start" &&
        /^deploy-vhost@.+\.service$/.test(action.lookup("unit")) &&
        subject.isInGroup("{{ vhosts_polkit_group }}")) {
        return polkit.Result.YES;
    }
});

# Authentication for SQL users. Included from 10-auth.conf.
#
# <https://doc.dovecot.org/latest/core/config/auth/databases/sql.html>
#
# In Dovecot 2.4 passdb/userdb use the driver name as the section name
# (passdb sql / userdb sql). The old free-form "args = <path>" pointing at
# dovecot-sql.conf.ext was removed: the SQL driver, connection settings and
# queries are now expressed as regular 2.4 settings. Define sql_driver and a
# named connection block (e.g. "mysql <host> { ... }") together with the
# password_query / user_query below to match your database schema.

#sql_driver = mysql
#mysql {{dovecot_postfixadmin_mysql_host}} {
#  user = {{dovecot_postfixadmin_mysql_username}}
#  dbname = {{dovecot_postfixadmin_mysql_database}}
#}

passdb sql {
  #default_password_scheme = CRYPT
  #query = SELECT password FROM mailbox WHERE username = '%{user}' AND active = '1'
}

userdb sql {

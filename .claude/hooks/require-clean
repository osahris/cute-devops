#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 Markus Katharina Brechtel <markus.katharina.brechtel@thengo.net>
# SPDX-License-Identifier: EUPL-1.2
#
# Claude Code Stop hook — refuse to end the session while the worktree has
# uncommitted changes, so work always lands as a commit (where git hooks — lint,
# tests — can gate it). Reads the hook JSON on stdin and blocks via a
# {"decision":"block"} response; a clean tree (or the bare pad) exits 0.
# Canonical copy tracked on main; the worktrees role scaffolds an initial copy
# into the work directory (the pad).
set -euo pipefail

payload="$(cat || true)"

extract() {
  printf '%s' "$payload" \
    | sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" \
    | head -n1
}
dir="$(extract cwd)"
[ -z "$dir" ] && dir="$PWD"

# Not inside a real (non-bare) work tree — e.g. the lookup pad. Nothing to
# commit here, so allow the session to end.
if [ "$(git -C "$dir" rev-parse --is-inside-work-tree 2>/dev/null || echo false)" != "true" ]; then
  exit 0
fi

dirty="$(git -C "$dir" status --porcelain 2>/dev/null || true)"
if [ -z "$dirty" ]; then
  exit 0
fi

n="$(printf '%s\n' "$dirty" | grep -c . || true)"
printf '{"decision":"block","reason":"This worktree has %s uncommitted change(s). Commit your work before finishing: review `git status`, then `git add` and `git commit` on the <category>/<branch> branch. This Stop hook enforces a clean tree so every change lands as a commit."}\n' "$n"
exit 0
